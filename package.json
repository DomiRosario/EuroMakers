{
  "name": "euromakers",
  "private": true,
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "remix vite:build && cp -r data build/",
    "dev": "remix vite:dev",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "start": "remix-serve ./build/server/index.js",
    "typecheck": "tsc",
    "validate": "node --loader ts-node/esm scripts/validate-software.ts",
    "validate:js": "node scripts/validate.js"
  },
  "dependencies": {
    "@marsidev/react-turnstile": "^1.4.2",
    "@remix-run/node": "^2.16.7",
    "@remix-run/react": "^2.16.7",
    "@remix-run/serve": "^2.16.7",
    "@types/nodemailer": "^7.0.11",
    "chalk": "^5.6.2",
    "country-flag-icons": "^1.6.15",
    "daisyui": "^5.5.19",
    "isbot": "^5.1.35",
    "nodemailer": "^8.0.2",
    "posthog-node": "^5.28.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.6.0",
    "sanitize-html": "^2.17.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@remix-run/dev": "^2.16.7",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/sanitize-html": "^2.16.1",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "engines": {
    "node": ">=22 <25"
  },
  "overrides": {
    "esbuild": "^0.25.12",
